# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/brandboost-ai

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# AI provider (used by the AI Marketing Generator + SEO Assistant)
# Default = OpenAI (paid). Leave AI_BASE_URL and AI_MODEL blank to use OpenAI.
#
# FREE alternative: Groq (openai-compatible, free tier, fast Llama models)
#   1. Sign up at https://console.groq.com, create an API key
#   2. Set:
#        OPENAI_API_KEY=your_groq_key
#        AI_BASE_URL=https://api.groq.com/openai/v1
#        AI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=
AI_MODEL=

# CORS - your frontend URL
CLIENT_URL=http://localhost:3000
